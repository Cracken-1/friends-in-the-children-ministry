generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  super_admin
}

enum ContentStatus {
  draft
  published
  archived
}

enum SubscriberStatus {
  pending
  active
  unsubscribed
}

enum PaymentProvider {
  mpesa
  airtel
}

enum PaymentStatus {
  pending
  processing
  completed
  failed
  cancelled
}

enum ImportStatus {
  queued
  pending
  processing
  completed
  failed
}

enum AuditAction {
  create
  update
  delete
  publish
  login
  logout
  export
  system
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  role         UserRole @default(admin)
  passwordHash String?  @map("password_hash")
  displayName  String?  @map("display_name")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  auditLogs AdminAuditLog[]

  @@map("users")
}

model Lesson {
  id          String        @id @default(uuid()) @db.Uuid
  title       String
  slug        String        @unique
  summary     String?
  content     String
  ageGroup    String        @map("age_group")
  className   String?       @map("class")
  duration    Int?
  difficulty  String?
  status      ContentStatus @default(draft)
  publishedAt DateTime?     @map("published_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  attachments     LessonAttachment[]
  telegramImports TelegramImport[]

  @@index([status, ageGroup])
  @@index([slug])
  @@map("lessons")
}

model LessonAttachment {
  id        String   @id @default(uuid()) @db.Uuid
  lessonId  String   @map("lesson_id") @db.Uuid
  filename  String
  url       String
  size      Int
  mimeType  String   @map("mime_type")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("lesson_attachments")
}

model BibleStudy {
  id          String        @id @default(uuid()) @db.Uuid
  title       String
  slug        String        @unique
  summary     String?
  content     String
  featured    Boolean       @default(false)
  status      ContentStatus @default(draft)
  publishedAt DateTime?     @map("published_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([status, featured])
  @@map("bible_studies")
}

model BlogPost {
  id          String        @id @default(uuid()) @db.Uuid
  title       String
  slug        String        @unique
  excerpt     String?
  content     String
  status      ContentStatus @default(draft)
  premium     Boolean       @default(false)
  priceCents  Int?          @map("price_cents")
  publishedAt DateTime?     @map("published_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([status, premium])
  @@map("blog_posts")
}

model Resource {
  id          String        @id @default(uuid()) @db.Uuid
  title       String
  slug        String        @unique
  description String?
  fileUrl     String        @map("file_url")
  fileType    String        @map("file_type")
  status      ContentStatus @default(draft)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([status, fileType])
  @@map("resources")
}

model Event {
  id          String        @id @default(uuid()) @db.Uuid
  title       String
  slug        String        @unique
  description String
  startsAt    DateTime      @map("starts_at")
  location    String?
  status      ContentStatus @default(draft)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([status, startsAt])
  @@map("events")
}

model TeachingTip {
  id        String        @id @default(uuid()) @db.Uuid
  title     String
  content   String
  status    ContentStatus @default(draft)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@map("teaching_tips")
}

model NewsletterSubscriber {
  id        String           @id @default(uuid()) @db.Uuid
  email     String           @unique
  status    SubscriberStatus @default(pending)
  tokenHash String           @map("token_hash")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  @@index([status])
  @@map("newsletter_subs")
}

model Payment {
  id              String          @id @default(uuid()) @db.Uuid
  userRef         String?         @map("user_ref")
  amountCents     Int             @map("amount_cents")
  provider        PaymentProvider
  status          PaymentStatus   @default(pending)
  reference       String          @unique
  checkoutRequest String?         @map("checkout_request")
  callbackPayload Json?           @map("callback_payload")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  premiumTokens PremiumToken[]
  logs          PaymentLog[]

  @@index([provider, status])
  @@map("payments")
}

model PaymentLog {
  id        String   @id @default(uuid()) @db.Uuid
  paymentId String?  @map("payment_id") @db.Uuid
  provider  String
  reference String?
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")

  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([provider, reference])
  @@map("payment_logs")
}

model PremiumToken {
  id          String   @id @default(uuid()) @db.Uuid
  paymentId   String   @map("payment_id") @db.Uuid
  contentId   String   @map("content_id") @db.Uuid
  contentType String   @map("content_type")
  tokenHash   String   @unique @map("token_hash")
  usedAt      DateTime? @map("used_at")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([contentId, contentType])
  @@map("premium_tokens")
}

model TelegramImport {
  id             String       @id @default(uuid()) @db.Uuid
  messageId      String       @unique @map("message_id")
  rawContent     Json         @map("raw_content")
  status         ImportStatus @default(queued)
  mappedLessonId String?      @map("mapped_lesson_id") @db.Uuid
  errorMessage   String?      @map("error_message")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  mappedLesson Lesson? @relation(fields: [mappedLessonId], references: [id], onDelete: SetNull)

  @@index([status])
  @@map("telegram_imports")
}

model Backup {
  id        String   @id @default(uuid()) @db.Uuid
  filename  String
  size      Int
  checksum  String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("backups")
}

model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model AdminAuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  actorId    String?     @map("actor_id") @db.Uuid
  action     AuditAction
  entityType String      @map("entity_type")
  entityId   String?     @map("entity_id") @db.Uuid
  metadata   Json?
  createdAt  DateTime    @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, action])
  @@index([entityType, entityId])
  @@map("admin_audit_log")
}
